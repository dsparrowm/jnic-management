# Local Next.js frontend → deployed Render API
# Copy to .env.local and fill in your values:
#   cp apps/web/.env.local.example apps/web/.env.local
#
# Restart `pnpm dev` after changing this file.

# Your Render API URL (no trailing slash)
# Example: https://jnlop-api.onrender.com
NEXT_PUBLIC_API_URL=
