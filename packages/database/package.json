{
  "name": "@repo/database",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "build": "prisma generate && tsc",
    "dev": "tsc --watch",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "push": "prisma db push",
    "seed": "prisma db seed",
    "check-types": "tsc --noEmit",
    "lint": "echo \"No lint configured for @repo/database\""
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.15.21",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  }
}
