# Database (local Docker defaults)
DATABASE_URL="postgresql://jnlop:jnlop_dev@localhost:5432/jnlop?schema=public"

# Redis (local Docker defaults)
REDIS_URL="redis://localhost:6379"

# API (Render sets PORT automatically)
PORT=4000
API_PORT=4000
WEB_ORIGIN="http://localhost:3000,http://localhost:3001,http://localhost:3002"
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Web (local dev — full stack)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Web (local frontend only — see apps/web/.env.local.example)
# NEXT_PUBLIC_API_URL="https://your-api.onrender.com"

# Seed (local / first deploy)
SEED_ADMIN_EMAIL="admin@jnic.org"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Platform Admin"
SEED_LP_EMAIL="lead@jnic.org"
SEED_LP_PASSWORD="ChangeMe123!"
SEED_LP_NAME="Lead Pastor"
RESEND_API_KEY=""
EMAIL_FROM="JNLOP <onboarding@jnic.org>"

# Cloudflare R2 (Phase 3)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="jnlop-profiles"
R2_PUBLIC_URL=""
